import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import warnings

warnings.filterwarnings('ignore')
sns.set_style("whitegrid")
plt.rcParams['figure.figsize'] = (10,6)

%matplotlib inline
df = pd.read_csv("customer_data.csv")

print("Dataset Shape:", df.shape)
df.head()
df = pd.read_csv("customer_data.csv")

print("Dataset Shape:", df.shape)
df.head()
