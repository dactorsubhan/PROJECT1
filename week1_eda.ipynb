df.info()
df.describe()
## 2. Data Cleaning
print("Missing Values:\n")
print(df.isnull().sum())

# Convert TotalCharges to numeric
df['TotalCharges'] = pd.to_numeric(df['TotalCharges'], errors='coerce')

# Fill missing values
df['TotalCharges'].fillna(df['TotalCharges'].median(), inplace=True)

print("\nMissing Values After Cleaning:\n")
print(df.isnull().sum())
df['Churn'].value_counts()

df['Churn'].value_counts(normalize=True)*100
plt.figure()
sns.histplot(df['tenure'], bins=30)
plt.title("Tenure Distribution")
plt.show()

sns.boxplot(x='Churn', y='tenure', data=df)
plt.title("Tenure vs Churn")
plt.show()
sns.histplot(df['MonthlyCharges'], bins=30)
plt.title("Monthly Charges Distribution")
plt.show()

sns.boxplot(x='Churn', y='MonthlyCharges', data=df)
plt.title("Monthly Charges vs Churn")
plt.show()
sns.violinplot(x='Churn', y='TotalCharges', data=df)
plt.title("Total Charges vs Churn")
plt.show()

sns.scatterplot(x='tenure', y='TotalCharges', hue='Churn', data=df, alpha=0.5)
plt.title("Tenure vs Total Charges")
plt.show()
contract_churn = pd.crosstab(df['Contract'], df['Churn'], normalize='index')*100
contract_churn.plot(kind='bar')
plt.title("Churn Rate by Contract Type")
plt.ylabel("Percentage")
plt.show()
internet_churn = pd.crosstab(df['InternetService'], df['Churn'], normalize='index')*100
internet_churn['Yes'].plot(kind='bar')
plt.title("Churn Rate by Internet Service")
plt.ylabel("Churn Rate (%)")
plt.show()
payment_churn = pd.crosstab(df['PaymentMethod'], df['Churn'], normalize='index')*100
payment_churn['Yes'].sort_values().plot(kind='barh')
plt.title("Churn Rate by Payment Method")
plt.xlabel("Churn Rate (%)")
plt.show()
df_numeric = df.copy()

binary_cols = ['Churn','Partner','Dependents','PhoneService','PaperlessBilling']

for col in binary_cols:
    if col in df_numeric.columns:
        df_numeric[col] = df_numeric[col].map({'Yes':1,'No':0})

numeric_df = df_numeric.select_dtypes(include=[np.number])
churn_corr = numeric_df.corr()['Churn'].sort_values(ascending=False)

churn_corr.plot(kind='barh')
plt.title("Correlation with Churn")
plt.show()
plt.figure(figsize=(12,10))
sns.heatmap(numeric_df.corr(), annot=True, fmt=".2f", cmap="coolwarm")
plt.title("Correlation Heatmap")
plt.show()
## 6. Key Insights and Findings

### High-Risk Customers:
- Customers with month-to-month contracts have the highest churn rate.
- Customers with low tenure (new customers) churn more frequently.
- Higher monthly charges are associated with higher churn.
- Fiber optic internet users show higher churn compared to DSL users.
- Electronic check payment users have higher churn rates.

### Observed Patterns:
- Overall churn rate is approximately 26%.
- Tenure has strong negative correlation with churn.
- Total charges increase with tenure.
- Long-term contracts significantly reduce churn probability.

### Recommendations:
- Encourage customers to switch to yearly contracts.
- Provide retention offers to new customers.
- Investigate dissatisfaction among fiber optic users.
- Offer discounts to high monthly charge customers.

